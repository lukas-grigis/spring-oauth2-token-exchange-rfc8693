{
  "name": "frontend-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "api:generate": "openapi-ts -i http://localhost:8000/api-docs -o src/api/generated/gateway && openapi-ts -i http://localhost:8000/talk-service/api-docs -o src/api/generated/talk-service && openapi-ts -i http://localhost:8000/review-service/api-docs -o src/api/generated/review-service",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "lint": "eslint src"
  },
  "dependencies": {
    "keycloak-js": "^26.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.6.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.94.5",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.0",
    "vite": "^8.0.3"
  }
}
